@model ToplulukYonetimSistemi.Models.Member

@{
    ViewData["Title"] = "Üyeyi Sil";
}

<section class="page-heading">
    <div>
        <p class="eyebrow">Silme Onayı</p>
        <h1>Üyeyi Sil</h1>
    </div>
    <a asp-action="Index" class="btn btn-soft">Vazgeç</a>
</section>

<div class="info-panel">
    <p class="delete-warning">
        @Model.FullName adlı üyeyi silmek istediğinize emin misiniz?
    </p>

    <dl>
        <dt>E-Posta</dt>
        <dd>@(Model.Email ?? "-")</dd>
        <dt>Bölüm</dt>
        <dd>@(Model.Department ?? "-")</dd>
        <dt>Topluluklar</dt>
        <dd>
            @if (Model.MemberCommunities.Any())
            {
                <div class="tag-list">
                    @foreach (var community in Model.MemberCommunities)
                    {
                        <span class="member-tag">@community.Community?.Name</span>
                    }
                </div>
            }
            else
            {
                <span>Topluluk yok</span>
            }
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger btn-action">Üyeyi Sil</button>
    </form>
</div>
