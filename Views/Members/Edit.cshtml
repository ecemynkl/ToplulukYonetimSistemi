@model ToplulukYonetimSistemi.Models.MemberCreateViewModel

@{
    ViewData["Title"] = "Üyeyi Düzenle";
}

<section class="page-heading">
    <div>
        <h1>Üyeyi Düzenle</h1>
    </div>
    <a asp-action="Index" class="btn btn-soft">Listeye Dön</a>
</section>

<form asp-action="Edit" enctype="multipart/form-data" class="surface-form">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Id" />

    <div class="form-grid">
        <div class="mb-3">
            <label asp-for="FullName" class="form-label"></label>
            <input asp-for="FullName" class="form-control" />
            <span asp-validation-for="FullName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="StudentNumber" class="form-label"></label>
            <input asp-for="StudentNumber" class="form-control" />
            <span asp-validation-for="StudentNumber" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Phone" class="form-label"></label>
            <input asp-for="Phone" class="form-control" />
            <span asp-validation-for="Phone" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Department" class="form-label"></label>
            <input asp-for="Department" class="form-control" />
            <span asp-validation-for="Department" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-4">
        <label class="form-label">Profil Resmi</label>
        <input type="file" name="profileImage" class="form-control" accept="image/*" />
        @if (!string.IsNullOrWhiteSpace(Model.ProfileImagePath))
        {
            <small class="form-text text-muted">Mevcut profil resmi korunur; yeni resim seçerseniz güncellenir.</small>
        }
    </div>

    <div class="mb-4">
        <label class="form-label">Üye Olduğu Topluluklar</label>

        <div class="choice-grid">
            @foreach (var community in Model.Communities)
            {
                <label class="choice-card">
                    <input type="checkbox" name="SelectedCommunityIds" value="@community.Value" checked="@community.Selected" />
                    <span>@community.Text</span>
                </label>
            }
        </div>
    </div>

    <button type="submit" class="btn btn-primary btn-action">
        <i class="bi bi-check-circle"></i> Değişiklikleri Kaydet
    </button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
