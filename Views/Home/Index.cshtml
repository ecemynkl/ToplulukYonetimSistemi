@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="container mt-5">

    <div class="p-5 mb-5 bg-dark text-white rounded-4 shadow-lg">

        <div class="container-fluid py-5">

            <h1 class="display-3 fw-bold">
                Kampüs Topluluk Platformu
            </h1>

            <p class="fs-5 mt-4 col-md-8">
                Üniversite topluluklarını keşfet,
                etkinliklere katıl ve kampüs hayatını daha aktif hale getir.
            </p>

            <div class="mt-4">

                <a asp-controller="Communities"
                   asp-action="Index"
                   class="btn btn-primary btn-lg me-2">

                    Toplulukları Gör
                </a>

                <a asp-controller="CommunityEvents"
                   asp-action="Index"
                   class="btn btn-outline-light btn-lg">

                    Etkinlikleri İncele
                </a>

            </div>

        </div>

    </div>

    <div class="row text-center">

        <div class="col-md-4 mb-4">

            <div class="card border-0 shadow-sm h-100">

                <div class="card-body">

                    <h3 class="fw-bold">
                        Topluluklar
                    </h3>

                    <p class="text-muted mt-3">
                        Kampüsteki toplulukları keşfet ve ilgini çeken gruplara katıl.
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-4">

            <div class="card border-0 shadow-sm h-100">

                <div class="card-body">

                    <h3 class="fw-bold">
                        Etkinlikler
                    </h3>

                    <p class="text-muted mt-3">
                        Güncel etkinlikleri görüntüle ve etkinliklere katılım sağla.
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-4">

            <div class="card border-0 shadow-sm h-100">

                <div class="card-body">

                    <h3 class="fw-bold">
                        Kampüs Hayatı
                    </h3>

                    <p class="text-muted mt-3">
                        Sosyal çevreni geliştir ve üniversite deneyimini daha eğlenceli hale getir.
                    </p>

                </div>

            </div>

        </div>

    </div>

</div>