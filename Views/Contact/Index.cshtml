@model ToplulukYonetimSistemi.Models.ContactMessage

@{
    ViewData["Title"] = "İletişim";
}

<section class="page-heading">
    <div>
        <h1>İletişim</h1>
    </div>
</section>

@if (TempData["ContactSuccess"] != null)
{
    <div class="alert alert-success">
        @TempData["ContactSuccess"]
    </div>
}

<div class="contact-layout">
    <form asp-action="Index" method="post" class="surface-form contact-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="contact-user-summary">
            <i class="bi bi-person-check-fill"></i>
            <div>
                <span>Gönderen</span>
                <strong>@Model.FullName</strong>
                <small>@Model.Email</small>
            </div>
        </div>

        <input type="hidden" asp-for="FullName" />
        <input type="hidden" asp-for="Email" />

        <div class="mb-4">
            <label asp-for="Message" class="form-label"></label>
            <textarea asp-for="Message" class="form-control" rows="6" placeholder="Mesajınızı yazınız"></textarea>
            <span asp-validation-for="Message" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary btn-action">Mesaj Gönder</button>
    </form>

    <aside class="contact-info-card">
        <h2>İletişim</h2>
        <div>
            <span>Adres</span>
            <strong>Yeniköy Altı Çalılık Mevki Yeniköy - Orhangazi / BURSA</strong>
        </div>
        <div>
            <span>Telefon</span>
            <strong>
                <a href="https://www.uludag.edu.tr/telefon" target="_blank" rel="noopener noreferrer">0 (224) 294 26 74</a>
            </strong>
            <strong>
                <a href="https://www.uludag.edu.tr/telefon" target="_blank" rel="noopener noreferrer">0 (224) 573 98 62</a>
            </strong>
        </div>
        <div>
            <span>E-Posta</span>
            <strong><a href="mailto:orhogis@uludag.edu.tr">orhogis@uludag.edu.tr</a></strong>
        </div>
        <p>Topluluklar, etkinlikler ve duyurular hakkında bizimle iletişime geçebilirsiniz.</p>
    </aside>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
