@model ToplulukYonetimSistemi.Models.CommunityEvent

@{
    ViewData["Title"] = "Etkinlik Detayları";
    var image = !string.IsNullOrWhiteSpace(Model.CoverImagePath)
        ? Url.Content(Model.CoverImagePath)
        : Url.Content("~/images/campus-hero.png");
}

<img src="@image" alt="@Model.Title etkinlik görseli" class="event-detail-cover" />

<section class="page-heading event-detail-heading">
    <div>
        <p class="eyebrow">Etkinlik Detayı</p>
        <h1>@(Model.Title ?? "Etkinlik")</h1>
    </div>
    <div class="button-row">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                <i class="bi bi-pencil-square"></i> Düzenle
            </a>
        }
        <a asp-action="Index" class="btn btn-soft">
            <i class="bi bi-arrow-left"></i> Listeye Dön
        </a>
    </div>
</section>

<div class="event-detail-grid">
    <div class="card event-info-card">
        <div class="card-body">
            <div class="event-info-icon">
                <i class="bi bi-calendar-event-fill"></i>
            </div>
            <span>Tarih</span>
            <strong>@Model.EventDate.ToString("dd MMMM yyyy")</strong>
        </div>
    </div>

    <div class="card event-info-card">
        <div class="card-body">
            <div class="event-info-icon">
                <i class="bi bi-people-fill"></i>
            </div>
            <span>Topluluk</span>
            <strong>@(Model.Community?.Name ?? "-")</strong>
        </div>
    </div>

    <div class="card event-info-card">
        <div class="card-body">
            <div class="event-info-icon">
                <i class="bi bi-clock-fill"></i>
            </div>
            <span>Durum</span>
            <strong>@(Model.EventDate >= DateTime.Today ? "Yaklaşan Etkinlik" : "Tamamlandı")</strong>
        </div>
    </div>
</div>

<div class="card event-description-card mt-4">
    <div class="card-body">
        <div class="management-card-title mb-3">
            <i class="bi bi-card-text"></i>
            <div>
                <h2>Açıklama</h2>
                <span>Etkinlik hakkında detaylı bilgi</span>
            </div>
        </div>
        <p>@(string.IsNullOrWhiteSpace(Model.Description) ? "Bu etkinlik için henüz açıklama eklenmedi." : Model.Description)</p>
    </div>
</div>
