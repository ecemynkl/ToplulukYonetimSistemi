@model ToplulukYonetimSistemi.Models.Announcement

@{
    ViewData["Title"] = "Yeni Duyuru";
}

<section class="page-heading">
    <div>
        <p class="eyebrow">Gündem</p>
        <h1>Yeni Duyuru Ekle</h1>
    </div>
    <a asp-action="Index" class="btn btn-soft">Listeye Dön</a>
</section>

<form asp-action="Create" enctype="multipart/form-data" class="surface-form">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    @await Html.PartialAsync("_Form", Model)
    <button type="submit" class="btn btn-primary btn-action">
        <i class="bi bi-check-circle"></i> Duyuruyu Kaydet
    </button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
