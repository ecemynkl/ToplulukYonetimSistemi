@model ToplulukYonetimSistemi.Models.Community

@{
    ViewData["Title"] = "Yeni Topluluk Oluştur";
}

<section class="page-heading">
    <div>
        <p class="eyebrow">Topluluk Yönetimi</p>
        <h1>Yeni Topluluk Oluştur</h1>
    </div>
    <a asp-action="Index" class="btn btn-soft">Listeye Dön</a>
</section>

<form asp-action="Create" enctype="multipart/form-data" class="surface-form">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-grid">
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="CreatedDate" class="form-label"></label>
            <input asp-for="CreatedDate" class="form-control" type="date" />
            <span asp-validation-for="CreatedDate" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-4">
        <label class="form-label">Kapak Görseli</label>
        <input type="file" name="coverImage" class="form-control" accept="image/*" />
    </div>

    <button type="submit" class="btn btn-primary btn-action">
        <i class="bi bi-check-circle"></i> Topluluğu Oluştur
    </button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
