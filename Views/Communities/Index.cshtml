@model IEnumerable<ToplulukYonetimSistemi.Models.Community>

@{
    ViewData["Title"] = "Topluluklar";
    var images = new[]
    {
        Url.Content("~/images/community-science.svg"),
        Url.Content("~/images/community-art.svg"),
        Url.Content("~/images/community-tech.svg"),
        Url.Content("~/images/community-sport.svg")
    };
}

<section class="page-heading">
    <div>
        <h1>Topluluklar</h1>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary btn-action">
            <i class="bi bi-plus-circle"></i> Yeni Topluluk Oluştur
        </a>
    }
</section>

@if (TempData["CommunitySuccess"] is string successMessage)
{
    <div class="alert alert-success alert-modern" role="alert">@successMessage</div>
}
@if (TempData["CommunityWarning"] is string warningMessage)
{
    <div class="alert alert-warning alert-modern" role="alert">@warningMessage</div>
}

<div class="management-card-grid">
    @foreach (var item in Model)
    {
        var image = !string.IsNullOrWhiteSpace(item.CoverImagePath)
            ? Url.Content(item.CoverImagePath)
            : images[Math.Abs(item.Id) % images.Length];
        var memberNames = item.MemberCommunities
            .Where(mc => mc.Member != null && !string.IsNullOrWhiteSpace(mc.Member.FullName))
            .Select(mc => mc.Member!.FullName!)
            .ToList();

        <article class="management-card">
            <img src="@image" alt="@item.Name topluluğu görseli" class="management-card-media" />
            <div class="management-card-body">
                <div class="management-card-title">
                    <i class="bi bi-building"></i>
                    <div>
                        <h2>@(item.Name ?? "Adsız Topluluk")</h2>
                        <span>@item.CreatedDate.ToString("dd.MM.yyyy") tarihinde oluşturuldu</span>
                    </div>
                </div>

                <p>@(string.IsNullOrWhiteSpace(item.Description) ? "Bu topluluk için henüz açıklama eklenmedi." : item.Description)</p>

                <div class="metric-row">
                    <span><i class="bi bi-person-check"></i> @memberNames.Count üye</span>
                </div>

                @if (User.IsInRole("Admin") && memberNames.Any())
                {
                    <div class="tag-list">
                        @foreach (var memberName in memberNames.Take(3))
                        {
                            <span class="member-tag">@memberName</span>
                        }
                        @if (memberNames.Count > 3)
                        {
                            <span class="member-tag muted">+@(memberNames.Count - 3)</span>
                        }
                    </div>
                }
            </div>

            <div class="management-card-actions icon-actions">
                <a asp-controller="CommunityEvents" asp-action="Index" asp-route-communityId="@item.Id" asp-route-upcomingOnly="true" class="btn btn-primary btn-sm">
                    <i class="bi bi-calendar-event"></i> Etkinlikler
                </a>
                @if (!User.IsInRole("Admin"))
                {
                    <form asp-action="RequestJoin" asp-route-id="@item.Id" method="post" class="d-inline">
                        <button type="submit" class="btn btn-soft btn-sm" data-confirm="Bu topluluğa katılmak istediğine emin misin?">
                            <i class="bi bi-send"></i> Katılma İsteği
                        </button>
                    </form>
                }
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-soft btn-sm icon-action-btn" data-bs-toggle="tooltip" data-bs-title="Detay" aria-label="Detay">
                    <i class="bi bi-eye-fill"></i>
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-soft btn-sm icon-action-btn" data-bs-toggle="tooltip" data-bs-title="Düzenle" aria-label="Düzenle">
                        <i class="bi bi-pencil-square"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm icon-action-btn" data-bs-toggle="tooltip" data-bs-title="Sil" aria-label="Sil">
                        <i class="bi bi-trash-fill"></i>
                    </a>
                }
            </div>
        </article>
    }
</div>
